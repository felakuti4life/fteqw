{
  "$schema": "https://raw.githubusercontent.com/microsoft/vcpkg/master/scripts/vcpkg.schema.json",
  "name": "fteqw",
  "version": "1.0",
  "dependencies": [
    "zlib",
    {
      "name": "bzip2",
      "features": ["tool"]
    },
    "libpng",
    {
      "name": "freetype",
      "features": ["brotli", "bzip2", "png", "zlib"]
    },
    "libjpeg-turbo",
    "libvorbis",
    "bullet3",
    "ode",
    "sdl2",
    "7zip",
    {
      "name": "gettext",
      "features": ["tools"]
    }
  ]
}
